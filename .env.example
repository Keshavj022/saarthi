# ---- Saarthi environment configuration ----
# Copy this file to `.env` and fill in values. NEVER commit your real .env.
#   cp .env.example .env

# Gemini API key — required from Phase 2 onward (the reasoning layer).
# Leave blank until then. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model to use (Phase 2+).
GEMINI_MODEL=gemini-1.5-flash

# SUMO is installed at the SYSTEM level (not pip). If SUMO_HOME is already
# exported in your shell, you may leave this blank; otherwise set it here, e.g.
#   SUMO_HOME=/opt/homebrew/opt/sumo/share/sumo
SUMO_HOME=

# Use the SUMO GUI (true) or run headless (false). Headless is much faster.
SUMO_GUI=false

# ---- Simulation defaults ----
SIM_SEED=42
SIM_STEP_LENGTH=1.0
SIM_DURATION=3600
