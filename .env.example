# ---- Saarthi environment configuration ----
# Copy this file to `.env` and fill in values. NEVER commit your real .env.
#   cp .env.example .env

# Anthropic API key — required from Phase 2 onward (the reasoning layer).
# Leave blank until then. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Claude model to use (Phase 2+). Override if you want a different tier
# (e.g. claude-sonnet-4-6 for lower cost, claude-haiku-4-5 for speed).
ANTHROPIC_MODEL=claude-opus-4-8

# SUMO_HOME is AUTO-DISCOVERED from the `eclipse-sumo` wheel (in requirements.txt),
# so you can normally leave this blank. Only set it if you have a separate SYSTEM
# SUMO install you want to use instead — it then takes precedence. e.g.
#   SUMO_HOME=/opt/homebrew/share/sumo
SUMO_HOME=

# Use the SUMO GUI (true) or run headless (false). Headless is much faster.
SUMO_GUI=false

# ---- Simulation defaults ----
SIM_SEED=42
SIM_STEP_LENGTH=1.0
SIM_DURATION=3600
