ANTHROPIC_API_KEY=

ANTHROPIC_MODEL=claude-haiku-4-5

# SUMO_HOME is AUTO-DISCOVERED from the `eclipse-sumo` wheel (in requirements.txt),
# so you can normally leave this blank. Only set it if you have a separate SYSTEM
# SUMO install you want to use instead — it then takes precedence. e.g.
#   SUMO_HOME=/opt/homebrew/share/sumo
SUMO_HOME=

# Use the SUMO GUI (true) or run headless (false). Headless is much faster.
SUMO_GUI=false

# Simulation defaults
SIM_SEED=42
SIM_STEP_LENGTH=1.0
SIM_DURATION=3600
