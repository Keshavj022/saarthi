# ---- Secrets / environment ----
.env

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ---- Data / generated artifacts ----
data/app.db
data/outputs/*
!data/outputs/.gitkeep
# Keep the demo-critical artifacts in the repo (all reproducible via scripts,
# but committed so the dashboard tells the story out-of-the-box).
!data/outputs/benchmark.png
!data/outputs/benchmark.json
!data/outputs/verdict.*.json
!data/outputs/advisory.*.json
!data/outputs/details.*.json
!data/outputs/temporal.json
data/videos/*
!data/videos/.gitkeep

# ---- Generated live-sim networks (rebuilt on demand by sim/network_defs.py) ----
sim/networks/gen/
sim/networks/net_*.net.xml

# ---- SUMO run artifacts (generated; the .net.xml is built from inputs) ----
*.tripinfo.xml
*.summary.xml
*.queue.xml
sumo.log
*.tmp

# ---- Model weights (perception, Phase 3+) ----
*.pt
*.pth
*.onnx

# ---- Tooling runtime state ----
.claude-flow/

# ---- OS ----
.DS_Store
