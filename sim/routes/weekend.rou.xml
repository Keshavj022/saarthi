<?xml version="1.0" encoding="UTF-8"?>
<!-- WEEKEND profile: moderate, BALANCED vehicle flow (no strong arterial
     dominance — N-S nearly matches E-W), with more turning trips and HEAVY
     pedestrian activity (shopping/leisure). The vehicle gain from adaptivity is
     smaller (flows are balanced) but the pedestrian-responsive walk phase earns
     its keep. Total ~2460 veh/h. -->
<routes>
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5.0"
           minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>
    <vType id="ped" vClass="pedestrian"/>

    <!-- East-West (moderate, more turns): through 400/h, turns 120/h each -->
    <flow id="W_E" type="car" begin="0" end="3600" from="W_in" to="E_out" vehsPerHour="400" departLane="best" departSpeed="max"/>
    <flow id="W_N" type="car" begin="0" end="3600" from="W_in" to="N_out" vehsPerHour="120" departLane="best" departSpeed="max"/>
    <flow id="W_S" type="car" begin="0" end="3600" from="W_in" to="S_out" vehsPerHour="120" departLane="best" departSpeed="max"/>
    <flow id="E_W" type="car" begin="0" end="3600" from="E_in" to="W_out" vehsPerHour="400" departLane="best" departSpeed="max"/>
    <flow id="E_N" type="car" begin="0" end="3600" from="E_in" to="N_out" vehsPerHour="120" departLane="best" departSpeed="max"/>
    <flow id="E_S" type="car" begin="0" end="3600" from="E_in" to="S_out" vehsPerHour="120" departLane="best" departSpeed="max"/>

    <!-- North-South (nearly balanced with E-W): through 350/h, turns 120/h each -->
    <flow id="N_S" type="car" begin="0" end="3600" from="N_in" to="S_out" vehsPerHour="350" departLane="best" departSpeed="max"/>
    <flow id="N_E" type="car" begin="0" end="3600" from="N_in" to="E_out" vehsPerHour="120" departLane="best" departSpeed="max"/>
    <flow id="N_W" type="car" begin="0" end="3600" from="N_in" to="W_out" vehsPerHour="120" departLane="best" departSpeed="max"/>
    <flow id="S_N" type="car" begin="0" end="3600" from="S_in" to="N_out" vehsPerHour="350" departLane="best" departSpeed="max"/>
    <flow id="S_E" type="car" begin="0" end="3600" from="S_in" to="E_out" vehsPerHour="120" departLane="best" departSpeed="max"/>
    <flow id="S_W" type="car" begin="0" end="3600" from="S_in" to="W_out" vehsPerHour="120" departLane="best" departSpeed="max"/>

    <!-- Pedestrians: heavy weekend foot traffic -->
    <personFlow id="p_WN" type="ped" begin="0" end="3600" perHour="60"><walk from="W_in" to="N_out"/></personFlow>
    <personFlow id="p_WS" type="ped" begin="0" end="3600" perHour="60"><walk from="W_in" to="S_out"/></personFlow>
    <personFlow id="p_EN" type="ped" begin="0" end="3600" perHour="60"><walk from="E_in" to="N_out"/></personFlow>
    <personFlow id="p_ES" type="ped" begin="0" end="3600" perHour="60"><walk from="E_in" to="S_out"/></personFlow>
    <personFlow id="p_NE" type="ped" begin="0" end="3600" perHour="60"><walk from="N_in" to="E_out"/></personFlow>
    <personFlow id="p_NW" type="ped" begin="0" end="3600" perHour="60"><walk from="N_in" to="W_out"/></personFlow>
    <personFlow id="p_SE" type="ped" begin="0" end="3600" perHour="60"><walk from="S_in" to="E_out"/></personFlow>
    <personFlow id="p_SW" type="ped" begin="0" end="3600" perHour="60"><walk from="S_in" to="W_out"/></personFlow>
</routes>
